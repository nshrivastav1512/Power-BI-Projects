{
  "name": "DWR Warm Beige Final",
  "dataColors": [
    "#8B5A2B", 
    "#2F3640", 
    "#D9CAB3", 
    "#6D6E71", 
    "#A4B0BD", 
    "#95A5A6", 
    "#E1E1E1", 
    "#2C3E50"
  ],
  "background": "#F5F1EE",
  "foreground": "#2F3640",
  "tableAccent": "#8B5A2B",
  "visualStyles": {
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#F5F1EE" } }, "transparency": 0 }]
      }
    },
    "*": {
      "*": {
        "*": [{ "fontFamily": "Georgia", "fontSize": 10, "color": { "solid": { "color": "#2F3640" } } }],
        "title": [{
          "show": true,
          "fontColor": { "solid": { "color": "#2F3640" } },
          "fontSize": 14,
          "fontFamily": "Georgia",
          "alignment": "Left"
        }],
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "show": true, "radius": 10, "color": { "solid": { "color": "#FFFFFF" } } }],
        "dropShadow": [{ "show": true, "color": { "solid": { "color": "#000000" } }, "position": "Outer", "preset": "Custom", "blur": 10, "transparency": 85, "angle": 90, "distance": 2 }]
      }
    },
    "card": {
      "*": {
        "labels": [{ "color": { "solid": { "color": "#2F3640" } }, "fontSize": 45, "fontFamily": "Georgia" }],
        "categoryLabels": [{ "color": { "solid": { "color": "#6D6E71" } }, "fontSize": 12, "fontFamily": "Georgia" }]
      }
    },
    "slicer": {
      "*": {
        "header": [{ 
          "fontColor": { "solid": { "color": "#8B5A2B" } }, 
          "textSize": 11, 
          "fontFamily": "Georgia Bold" 
        }],
        "items": [{ 
          "fontColor": { "solid": { "color": "#2F3640" } }, 
          "background": { "solid": { "color": "#FFFFFF" } },
          "accessibilityContrastProperties": true
        }],
        "border": [{ "show": false }],
        "background": [{ "show": false }]
      }
    }
  }
}
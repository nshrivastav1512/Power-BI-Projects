{
  "name": "DWR Premium Beige Fixed",
  "dataColors": [
    "#8B5A2B", 
    "#4A4A4A", 
    "#B09F85", 
    "#5F6B75", 
    "#D65A5A", 
    "#8C9CA8", 
    "#D9CAB3", 
    "#2C3E50"
  ],
  "background": "#FFFFFF",
  "foreground": "#4A4A4A",
  "tableAccent": "#8B5A2B",
  "visualStyles": {
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#E8E4DF" } }, "transparency": 0 }]
      }
    },
    "*": {
      "*": {
        "*": [{ "fontFamily": "Segoe UI", "fontSize": 10, "color": { "solid": { "color": "#4A4A4A" } } }],
        "title": [{
          "show": true,
          "fontColor": { "solid": { "color": "#2F2F2F" } },
          "fontSize": 14,
          "fontFamily": "Georgia",
          "alignment": "Left"
        }],
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "show": true, "radius": 12, "color": { "solid": { "color": "#FFFFFF" } } }],
        "dropShadow": [{ "show": true, "color": { "solid": { "color": "#000000" } }, "position": "Outer", "preset": "Custom", "blur": 15, "transparency": 85, "angle": 90, "distance": 2 }]
      }
    },
    "card": {
      "*": {
        "labels": [{ "color": { "solid": { "color": "#2F2F2F" } }, "fontSize": 35, "fontFamily": "DIN" }],
        "categoryLabels": [{ "color": { "solid": { "color": "#8B5A2B" } }, "fontSize": 12, "fontFamily": "Segoe UI Semibold" }]
      }
    },
    "slicer": {
      "*": {
        "header": [{ 
          "fontColor": { "solid": { "color": "#8B5A2B" } }, 
          "textSize": 11, 
          "fontFamily": "Segoe UI Bold" 
        }],
        "items": [{ 
          "fontColor": { "solid": { "color": "#4A4A4A" } }, 
          "background": { "solid": { "color": "#FFFFFF" } },
          "accessibilityContrastProperties": true
        }],
        "border": [{ "show": false }],
        "background": [{ "show": false }]
      }
    },
    "shape": {
      "*": {
        "fill": [{ "transparency": 0, "fillColor": { "solid": { "color": "#FFFFFF" } } }]
      }
    },
    "actionButton": {
      "*": {
        "fill": [{ "fillColor": { "solid": { "color": "#8B5A2B" } }, "transparency": 0 }],
        "text": [{ "fontColor": { "solid": { "color": "#FFFFFF" } }, "fontFamily": "Segoe UI Bold" }],
        "border": [{ "show": false }]
      }
    }
  }
}